  <RhapsodyProfile:RhpModelElement xmi:id="GUID+b8f1f7d2-172b-4f47-beb3-d53758a0abad_Stereotype_RhapsodyProfile_RhpModelElement" guid="GUID b8f1f7d2-172b-4f47-beb3-d53758a0abad" description="This stereotype tells Rhapsody what is the DefaultType when creating a new term element based on 'Part' or 'Variable'. &#xD;&#xA;The user will add to the new term a dependency (with the 'DefaultType' stereotype) on a certain Model Element type, which will be the default type upon creation of the new term element. For example see 'ProxyPort' in the SysML profile." descriptionHTML="&lt;![[CDATA[This stereotype tells Rhapsody what is the DefaultType when creating a new term element based on 'Part' or 'Variable'. &#xD;&#xA;The user will add to the new term a dependency (with the 'DefaultType' stereotype) on a certain Model Element type, which will be the default type upon creation of the new term element. For example see 'ProxyPort' in the SysML profile.]]>" descriptionRTF="&lt;![[CDATA[{\rtf1\fbidis\ansi\ansicpg1255\deff0\deflang1037{\fonttbl{\f0\fnil\fcharset0 Arial;}}&#xD;&#xA;\viewkind4\uc1\pard\ltrpar\fs20 This stereotype tells Rhapsody what is the DefaultType when creating a new term element based on 'Part' or 'Variable'. \par&#xD;&#xA;The user will add to the new term a dependency (with the 'DefaultType' stereotype) on a certain Model Element type, which will be the default type upon creation of the new term element. For example see 'ProxyPort' in the SysML profile.\par&#xD;&#xA;}&#xD;&#xA;]]>" base_Stereotype="GUID+b8f1f7d2-172b-4f47-beb3-d53758a0abad" base_Class="GUID+b8f1f7d2-172b-4f47-beb3-d53758a0abad"/>
  <RHP:RHPStereotype xmi:id="GUID+b8f1f7d2-172b-4f47-beb3-d53758a0abad_Stereotype_RHP_RHPStereotype" SpecificationFilename="C:\LegacyApp\Rhapsody_902_64bit\Test\DefaultComponent\DefaultConfig\" ImplementationFilename="C:\LegacyApp\Rhapsody_902_64bit\Test\DefaultComponent\DefaultConfig\" IsBeingGenerated="TRUE" base_Stereotype="GUID+b8f1f7d2-172b-4f47-beb3-d53758a0abad" base_Class="GUID+b8f1f7d2-172b-4f47-beb3-d53758a0abad"/>
  <RhapsodyProfile:RhpStereotype xmi:id="GUID+b8f1f7d2-172b-4f47-beb3-d53758a0abad_Stereotype_RhapsodyProfile_RhpStereotype" base_Stereotype="GUID+b8f1f7d2-172b-4f47-beb3-d53758a0abad">
